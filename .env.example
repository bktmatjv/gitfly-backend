# ─── Node.js Backend ───────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── MongoDB — Autenticación del contenedor ────────────────────────
MONGO_ROOT_USER=giftly_admin
MONGO_ROOT_PASSWORD=CAMBIA_ESTA_CLAVE_SEGURA
MONGO_DB_NAME=giftly

# URI con autenticación (el backend la construye con las vars de arriba en docker-compose,
# pero puedes usarla directamente si corres el backend fuera de Docker)
MONGO_URI=mongodb://giftly_admin:CAMBIA_ESTA_CLAVE_SEGURA@localhost:27017/giftly?authSource=admin

# ─── JWT ────────────────────────────────────────────────────────────
JWT_SECRET=GENERA_UN_SECRET_LARGO_Y_ALEATORIO_AQUI

# ─── CORS ────────────────────────────────────────────────────────────
# En producción: tu dominio real. En local: puertos de desarrollo.
CORS_ORIGIN=http://localhost,http://localhost:5173,https://tudominio.com

# ─── Azure Blob Storage (para uploads de imágenes) ──────────────────
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=tu_cuenta;AccountKey=tu_key;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER_NAME=giftly-media
